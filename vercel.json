{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.2"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(favicon\\.ico|favicon\\.svg|manifest\\.json|robots\\.txt|sw\\.js)",
            "dest": "/public/$1"
        },
        {
            "src": "/icons/(.*)",
            "dest": "/public/icons/$1"
        },
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Workshop Management System",
        "APP_KEY": "base64:ejC4SWc4F0xu9OtscryeNpB7Gsjb3rzN5fUHIKNx3gc=",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://suhaimsoftwokrhsop.vercel.app",
        "DB_CONNECTION": "mysql",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "LOG_CHANNEL": "stderr"
    }
}
